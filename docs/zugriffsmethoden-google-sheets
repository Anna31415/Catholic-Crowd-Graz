## 5. Datenvalidierung

**Die Website sollte diese Checks durchführen:**

```javascript
function validateEvent(event) {
  const errors = [];
  
  // Pflichtfelder
  if (!event.title?.trim()) errors.push('Titel fehlt');
  if (!event.organisation?.trim()) errors.push('Organisation fehlt');
  if (!event.date?.trim()) errors.push('Datum fehlt');
  if (!event.startTime?.trim()) errors.push('Anfangszeit fehlt');
  if (!event.location?.trim()) errors.push('Ort fehlt');
  
  // Format-Validierung
  const dateRegex = /^\d{4}-\d{2}-\d{2}$/; // YYYY-MM-DD
  if (event.date && !dateRegex.test(event.date)) {
    errors.push(`Datumsformat ungültig: ${event.date}`);
  }
  
  const timeRegex = /^\d{2}:\d{2}$/; // HH:MM
  if (!timeRegex.test(event.startTime)) {
    errors.push(`Anfangszeit ungültig: ${event.startTime}`);
  }
  
  // Vergangenheit filtern
  const eventDate = new Date(event.date);
  if (eventDate < new Date()) {
    errors.push(`Event liegt in der Vergangenheit: ${event.date}`);
  }
  
  return {
    valid: errors.length === 0,
    errors
  };
}
```

